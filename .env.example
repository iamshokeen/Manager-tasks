# .env.example — copy to .env.local and fill in values
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kairos"

# Auth (custom JWT, replaces NextAuth).
JWT_SECRET="generate-a-random-32-byte-hex-string-here"
ADMIN_EMAIL="you@example.com"

# Email — Gmail SMTP via nodemailer. SMTP_PASS must be a Gmail App Password
# (https://myaccount.google.com/apppasswords). Used by:
#   - cron /api/cron/send-briefs for the daily auto-brief
#   - the manual "Send brief" button on /reports/[userId]
#   - SA-only /api/admin/email-diag for diagnostics
SMTP_USER="kairos-sender@yourdomain.com"
SMTP_PASS="16-char-gmail-app-password"
REPORT_EMAIL_TO="ops@yourdomain.com"

# Vercel cron auth. Must match the value set in Vercel project env vars or
# the daily /api/cron/send-briefs hit will return 401 and no briefs go out.
CRON_SECRET="generate-a-random-string-here"

SHEETS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
SHEETS_SCRIPT_TOKEN="your-shared-secret-token"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob — file uploads for tasks / projects / messages. Get the
# token from `vercel blob` or the Vercel dashboard (Storage → Blob).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# AI (optional — only used by /email-to-tasks parser)
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY=""
