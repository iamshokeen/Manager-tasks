// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  SENIOR_IC
  DIRECT_REPORT
  EXEC_VIEWER
  GUEST
}

enum WorkspaceType {
  PLATFORM
  DEPARTMENT
  PROJECT
  PERSONAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  name                 String
  avatarUrl            String?
  role                 Role              @default(DIRECT_REPORT)
  isActive             Boolean           @default(true)
  emailVerified        Boolean           @default(false)
  verifyToken          String?
  verifyExpiry         DateTime?
  approvalStatus       ApprovalStatus    @default(PENDING)
  approvedBy           String?
  approvedAt           DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  managerId            String?
  manager              User?             @relation("ManagerToReports", fields: [managerId], references: [id])
  reports              User[]            @relation("ManagerToReports")
  // backward-compat link to existing TeamMember
  teamMemberId         String?           @unique
  teamMember           TeamMember?       @relation(fields: [teamMemberId], references: [id])
  workspaceMemberships WorkspaceMember[]
  sentInvites          Invite[]          @relation("InviteSender")
  kpiOverrides         KpiVisibility[]
  activityLogs         ActivityLog[]
  onboardingCompleted  Boolean           @default(false)
  kpiAccessRequest     KpiAccessRequest?
  createdTasks         Task[]            @relation("TaskCreator")
  createdFollowUps     FollowUp[]        @relation("FollowUpCreator")
  ownedNotes           Note[]            @relation("NoteOwner")
  ownedCadences        Cadence[]         @relation("CadenceOwner")
  createdOneOnOnes     OneOnOne[]        @relation("OneOnOneCreator")
  createdProjects      Project[]         @relation("ProjectCreator")
}

// ─── Workspaces ───────────────────────────────────────────────────────────────

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  type        WorkspaceType
  description String?
  isArchived  Boolean           @default(false)
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  invites     Invite[]
  kpiSettings KpiSetting[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        Role
  joinedAt    DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
}

// ─── Invites ──────────────────────────────────────────────────────────────────

model Invite {
  id          String       @id @default(cuid())
  email       String
  workspaceId String?
  role        Role
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  sentById    String
  createdAt   DateTime     @default(now())
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id])
  sentBy      User         @relation("InviteSender", fields: [sentById], references: [id])
}

// ─── KPI Visibility ───────────────────────────────────────────────────────────

model KpiSetting {
  id          String    @id @default(cuid())
  workspaceId String
  kpiKey      String
  visibleTo   Role[]
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, kpiKey])
}

model KpiVisibility {
  id        String  @id @default(cuid())
  userId    String
  kpiKey    String
  isVisible Boolean @default(true)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([userId, kpiKey])
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ─── Existing models (unchanged except TeamMember adds User relation) ─────────

model TeamMember {
  id              String        @id @default(cuid())
  name            String
  role            String
  department      String
  status          String        @default("active")
  skills          String?
  oneOnOneDay     String?
  oneOnOneTime    String?
  coachingNotes   String?       @db.Text
  hireDate        DateTime?
  delegationLevel Int           @default(1)
  tasks           Task[]
  oneOnOnes       OneOnOne[]
  emailThreads    EmailThread[]
  projects        Project[]
  followUps       FollowUp[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User?
}

model Project {
  id            String               @id @default(cuid())
  title         String
  description   String?              @db.Text
  department    String
  stage         String               @default("planning")
  ownerId       String?
  owner         TeamMember?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  stakeholderId String?
  stakeholder   Stakeholder?         @relation(fields: [stakeholderId], references: [id])
  stakeholders  ProjectStakeholder[]
  dueDate       DateTime?
  createdByUserId String?
  createdByUser User?                @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  tasks         Task[]
  followUps     FollowUp[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Task {
  id             String          @id @default(cuid())
  title          String
  description    String?         @db.Text
  assigneeId     String?
  assignee       TeamMember?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  isSelfTask     Boolean         @default(false)
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  department     String
  priority       String          @default("medium")
  status         String          @default("todo")
  dueDate        DateTime?
  completedAt    DateTime?
  stakeholderId  String?
  stakeholder    Stakeholder?    @relation(fields: [stakeholderId], references: [id], onDelete: SetNull)
  stakeholders   TaskStakeholder[]
  cadenceId      String?
  cadence        Cadence?        @relation(fields: [cadenceId], references: [id], onDelete: SetNull)
  emailThreads   TaskEmailLink[]
  activities     TaskActivity[]
  source         String          @default("manual")
  tags           String[]        @default([])
  assignedByName String?
  createdByUserId String?
  createdByUser  User?           @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  followUps      FollowUp[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TaskActivity {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type       String
  from       String?
  to         String?
  note       String?  @db.Text
  source     String   @default("user")
  authorName String?
  createdAt  DateTime @default(now())
}

model Stakeholder {
  id           String               @id @default(cuid())
  name         String
  title        String?
  frequency    String
  channel      String
  priority     String               @default("high")
  context      String?              @db.Text
  strategy     String?              @db.Text
  email        String?
  tasks        Task[]
  projects     Project[]
  taskLinks    TaskStakeholder[]
  projectLinks ProjectStakeholder[]
  followUps    FollowUp[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model TaskStakeholder {
  taskId        String
  stakeholderId String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stakeholder   Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@id([taskId, stakeholderId])
}

model ProjectStakeholder {
  projectId     String
  stakeholderId String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stakeholder   Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@id([projectId, stakeholderId])
}

model OneOnOne {
  id               String           @id @default(cuid())
  memberId         String
  member           TeamMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  date             DateTime
  mood             String           @default("neutral")
  theirUpdates     String?          @db.Text
  myUpdates        String?          @db.Text
  feedbackGiven    String?          @db.Text
  developmentNotes String?          @db.Text
  actionItems      OneOnOneAction[]
  createdByUserId  String?
  createdByUser    User?            @relation("OneOnOneCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
}

model OneOnOneAction {
  id          String    @id @default(cuid())
  oneOnOneId  String
  oneOnOne    OneOnOne  @relation(fields: [oneOnOneId], references: [id], onDelete: Cascade)
  action      String
  owner       String
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Cadence {
  id          String            @id @default(cuid())
  name        String
  type        String
  day         String
  time        String
  duration    Int               @default(30)
  scope       String
  description String?           @db.Text
  prepItems   CadencePrepItem[]
  tasks       Task[]
  isActive    Boolean           @default(true)
  userId      String?
  user        User?             @relation("CadenceOwner", fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model CadencePrepItem {
  id           String   @id @default(cuid())
  cadenceId    String
  cadence      Cadence  @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  title        String
  assigneeId   String?
  department   String?
  leadTimeDays Int      @default(1)
  createdAt    DateTime @default(now())
}

model EmailThread {
  id            String          @id @default(cuid())
  gmailThreadId String          @unique
  subject       String
  from          String
  to            String[]
  lastMessageAt DateTime
  snippet       String?         @db.Text
  status        String          @default("open")
  priority      String          @default("medium")
  assigneeId    String?
  assignee      TeamMember?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  tasks         TaskEmailLink[]
  labels        String[]        @default([])
  isStarred     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model TaskEmailLink {
  id            String      @id @default(cuid())
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  emailThreadId String
  emailThread   EmailThread @relation(fields: [emailThreadId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([taskId, emailThreadId])
}

model NumberEntry {
  id        String    @id @default(cuid())
  metric    String
  value     Float
  period    String
  source    String    @default("sheets")
  syncedAt  DateTime?
  createdAt DateTime  @default(now())

  @@unique([metric, period])
}

model Report {
  id        String    @id @default(cuid())
  type      String
  period    String
  data      Json
  emailedAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([type, period])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String?
  user      User?    @relation("NoteOwner", fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FollowUp {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  contactName     String
  teamMemberId    String?
  teamMember      TeamMember?    @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  stakeholderId   String?
  stakeholder     Stakeholder?   @relation(fields: [stakeholderId], references: [id], onDelete: SetNull)
  status          String         @default("open")
  parentId        String?
  parent          FollowUp?      @relation("FollowUpTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        FollowUp[]     @relation("FollowUpTree")
  reminderAt      DateTime?
  snoozedUntil    DateTime?
  autoRemind      Boolean        @default(true)
  lastActivityAt  DateTime       @default(now())
  taskId          String?
  task            Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  convertedTaskId String?
  createdByUserId String?
  createdByUser   User?          @relation("FollowUpCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  notes           FollowUpNote[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model FollowUpNote {
  id         String   @id @default(cuid())
  followUpId String
  followUp   FollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorName String?
  createdAt  DateTime @default(now())
}

model KpiAccessRequest {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, approved, denied
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
